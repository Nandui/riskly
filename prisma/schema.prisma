// Riskly — leisure-centre risk assessment schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime; direct/unpooled for migrations.
  // Neon's Vercel integration provides both names automatically.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A leisure centre / site. Top-level scoping dimension (one org, many centres).
model Center {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  address      String?
  contactName  String?
  contactEmail String?
  phone        String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  areas       Area[]
  assessments RiskAssessment[]
}

// Physical / functional area within a centre (poolside, gym floor, plant room...). Per-centre.
model Area {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]

  @@index([centerId])
}

// Staff role (lifeguard, fitness instructor...). Org-level shared library, reusable across centres.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// Activity (pool supervision, chemical handling...). Org-level shared library.
model Activity {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// The core document. Each assessment is ABOUT one subject — an area, a role
// or an activity (subjectType says which) — at a centre, and is named after it.
model RiskAssessment {
  id                    String    @id @default(cuid())
  reference             String    @unique
  description           String?
  centerId              String
  center                Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  subjectType           String    @default("Area") // Area | Role | Activity
  areaId                String?
  area                  Area?     @relation(fields: [areaId], references: [id])
  roleId                String?
  role                  Role?     @relation(fields: [roleId], references: [id])
  activityId            String?
  activity              Activity? @relation(fields: [activityId], references: [id])
  status                String    @default("Draft") // Draft | Active | UnderReview | Archived
  assessorName          String?
  approvedByName        String?
  assessmentDate        DateTime  @default(now())
  reviewFrequencyMonths Int       @default(12)
  lastReviewedDate      DateTime?
  nextReviewDate        DateTime
  version               Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  hazards        Hazard[]
  reviewLogs     ReviewLog[]
  reviewRequests ReviewRequest[]
  assignees      User[]          @relation("Assignees")

  @@index([centerId])
  @@index([areaId])
  @@index([roleId])
  @@index([activityId])
  @@index([status])
  @@index([nextReviewDate])
}

// Hazard line item: Hazard | Risk Factor | Person at Risk | Consequence |
// Current Controls | Likelihood × Consequence Severity = Overall Risk | Category.
model Hazard {
  id              String         @id @default(cuid())
  assessmentId    String
  assessment      RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sortOrder       Int            @default(0)
  hazard          String
  riskFactor      String?
  personAtRisk    String?
  consequence     String?
  currentControls String?
  likelihood      Int            @default(1) // 1-5
  severity        Int            @default(1) // 1-5 (consequence severity)
  riskCategory    String         @default("Physical")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([assessmentId])
  @@index([riskCategory])
}

// Audit trail of reviews — supports the monitoring story.
model ReviewLog {
  id             String         @id @default(cuid())
  assessmentId   String
  assessment     RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  reviewedDate   DateTime       @default(now())
  reviewerName   String?
  outcome        String         @default("NoChanges") // NoChanges | Updated | Escalated
  notes          String?
  nextReviewDate DateTime
  createdAt      DateTime       @default(now())

  @@index([assessmentId])
}

// ---- Authentication & users (Auth.js / NextAuth + Prisma adapter) ----

// App user. Auth.js fields + our role / active flag / relations.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("Viewer") // Viewer | Contributor | Reviewer | Assessor | Admin
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  assignedAssessments RiskAssessment[] @relation("Assignees")
  reviewRequestsMade  ReviewRequest[]  @relation("RequestedBy")
  reviewRequestsResolved ReviewRequest[] @relation("ResolvedBy")

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// A request (raised by a Contributor+) that an assessment be reviewed.
model ReviewRequest {
  id            String         @id @default(cuid())
  assessmentId  String
  assessment    RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User           @relation("RequestedBy", fields: [requestedById], references: [id])
  notes         String
  status        String         @default("Open") // Open | Actioned | Dismissed
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?          @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([assessmentId])
  @@index([status])
}
