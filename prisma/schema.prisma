// Riskly — leisure-centre risk assessment schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app at runtime; direct/unpooled for migrations.
  // Neon's Vercel integration provides both names automatically.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A leisure centre / site. Top-level scoping dimension (one org, many centres).
model Center {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  siteCode     String? // 2-letter code used in assessment references (RA-XX-0001)
  address      String?
  contactName  String?
  contactEmail String?
  phone        String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  areas       Area[]
  assessments RiskAssessment[]
  incidents   Incident[]
}

// Physical / functional area within a centre (poolside, gym floor, plant room...). Per-centre.
model Area {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
  subAreas    SubArea[]
  incidents   Incident[]

  @@index([centerId])
}

// Staff role (lifeguard, fitness instructor...). Org-level shared library, reusable across centres.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// Activity (pool supervision, chemical handling...). Org-level shared library.
model Activity {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// Organisational department that owns assessments (Ops, Maintenance, Accounts…).
// Org-level shared library, managed on the Library page.
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments RiskAssessment[]
}

// The core document. Each assessment is ABOUT one subject — an area, a role
// or an activity (subjectType says which) — at a centre, and is named after it.
model RiskAssessment {
  id                    String    @id @default(cuid())
  reference             String    @unique
  description           String?
  centerId              String
  center                Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  subjectType           String    @default("Area") // Area | Role | Activity
  areaId                String?
  area                  Area?     @relation(fields: [areaId], references: [id])
  roleId                String?
  role                  Role?     @relation(fields: [roleId], references: [id])
  activityId            String?
  activity              Activity? @relation(fields: [activityId], references: [id])
  ownerId               String?
  owner                 User?       @relation("OwnedBy", fields: [ownerId], references: [id])
  departmentId          String?
  department            Department? @relation(fields: [departmentId], references: [id])
  status                String    @default("Draft") // Draft | Active | UnderReview | Archived
  assessorName          String?
  ceoApprovedByName     String?   @map("approvedByName")
  ceoApprovedById       String?   @map("approvedById")
  ceoApprovedBy         User?     @relation("CeoApprovedBy", fields: [ceoApprovedById], references: [id])
  ceoApprovedAt         DateTime? @map("approvedAt")
  ownerApprovedByName   String?
  ownerApprovedById     String?
  ownerApprovedBy       User?     @relation("OwnerApprovedBy", fields: [ownerApprovedById], references: [id])
  ownerApprovedAt       DateTime?
  assessmentDate        DateTime  @default(now())
  reviewFrequencyMonths Int       @default(12)
  lastReviewedDate      DateTime?
  nextReviewDate        DateTime
  version               Int       @default(1)
  hazardSeq             Int       @default(0) // high-water mark for hazard seq allocation (never reused)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  hazards        Hazard[]
  reviewLogs     ReviewLog[]
  reviewRequests ReviewRequest[]
  auditLogs      AuditLog[]
  incidentLinks  IncidentRiskAssessmentLink[]

  @@index([centerId])
  @@index([areaId])
  @@index([roleId])
  @@index([activityId])
  @@index([ownerId])
  @@index([departmentId])
  @@index([status])
  @@index([nextReviewDate])
}

// Hazard line item: Hazard | Risk Factor | Person at Risk | Consequence |
// Current Controls | Likelihood × Consequence Severity = Overall Risk | Category.
model Hazard {
  id              String         @id @default(cuid())
  assessmentId    String
  assessment      RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sortOrder       Int            @default(0)
  seq             Int            // permanent per-assessment number for the hazard reference (RA-…-HZ-NNN); never reused
  hazard          String
  riskFactor      String?
  personAtRisk    String?
  consequence     String?
  currentControls String?
  likelihood      Int            @default(1) // 1-5
  severity        Int            @default(1) // 1-5 (consequence severity)
  riskCategory    String         @default("Physical")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([assessmentId, seq])
  @@index([assessmentId])
  @@index([riskCategory])
}

// Audit trail of reviews — supports the monitoring story.
model ReviewLog {
  id             String         @id @default(cuid())
  assessmentId   String
  assessment     RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  reviewedDate   DateTime       @default(now())
  reviewerName   String?
  outcome        String         @default("NoChanges") // NoChanges | Updated | Escalated
  notes          String?
  nextReviewDate DateTime
  createdAt      DateTime       @default(now())

  @@index([assessmentId])
}

// ---- Authentication & users (Auth.js / NextAuth, email + password) ----

// App user. Admins create accounts and assign roles; password is bcrypt-hashed.
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  image        String?
  passwordHash String?
  role         String   @default("Shift Supervisor") // Shift Supervisor | Duty Manager | Department Supervisor | CEO | Operations Manager
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedAssessments       RiskAssessment[] @relation("OwnedBy")
  ceoApprovedAssessments   RiskAssessment[] @relation("CeoApprovedBy")
  ownerApprovedAssessments RiskAssessment[] @relation("OwnerApprovedBy")
  reviewRequestsMade     ReviewRequest[]  @relation("RequestedBy")
  reviewRequestsResolved ReviewRequest[]  @relation("ResolvedBy")
  auditLogs              AuditLog[]       @relation("AuditActor")

  @@index([role])
}

// A request (raised by a Contributor+) that an assessment be reviewed.
model ReviewRequest {
  id            String         @id @default(cuid())
  assessmentId  String
  assessment    RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User           @relation("RequestedBy", fields: [requestedById], references: [id])
  notes         String
  status        String         @default("Open") // Open | Actioned | Dismissed
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?          @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolutionNote String?       // why it was actioned/dismissed, captured on resolve
  sourceIncidentId String?     // back-link to the incident whose close-out raised this (no FK)

  @@index([assessmentId])
  @@index([status])
}

// Append-only activity / change log for an assessment (created, edited,
// approved, reviewed, status changed…) — the audit trail.
model AuditLog {
  id            String          @id @default(cuid())
  assessmentId  String?
  assessment    RiskAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  assessmentRef String? // denormalised so the trail stays readable if the assessment is deleted
  userId        String?
  user          User?           @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  userName      String?
  action        String
  detail        String?
  createdAt     DateTime        @default(now())

  @@index([assessmentId])
  @@index([createdAt])
}

// ============================================================================
// Incidents module — incident reporting & the investigation / follow-up
// workflow. Reuses Center, Area and User from the risk-assessment side; adds a
// SubArea level under Area for precise incident locations.
// String-typed enums (PascalCase) match the rest of the schema; the allowed
// values + display metadata live in src/lib/incidents/constants.ts.
// ============================================================================

// A sub-location within an Area (poolside → shallow end, plant room → boiler…).
// Per-area; reused only by incidents for now.
model SubArea {
  id          String   @id @default(cuid())
  areaId      String
  area        Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidents Incident[]

  @@index([areaId])
}

// A reported incident at a centre. Reference: INC-XX-NNNN (XX = Center.siteCode).
model Incident {
  id              String    @id @default(cuid())
  reference       String    @unique // INC-XX-0001
  centerId        String
  center          Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  type            String // Accident | NearMiss | PropertyDamage | ViolenceAggression | HazardousSubstance | FireOrEvacuation | Other
  status          String    @default("Draft") // Draft | Open | UnderInvestigation | Closed
  severity        String // Minor | Significant | Reportable | Critical
  occurredAt      DateTime // exact date + time of the incident
  // Structured location: an Area (+ optional SubArea). location/locationDetail are
  // denormalised name copies so lists/dashboard/exports never join and survive deletes.
  areaId          String?
  area            Area?     @relation(fields: [areaId], references: [id], onDelete: SetNull)
  subAreaId       String?
  subArea         SubArea?  @relation(fields: [subAreaId], references: [id], onDelete: SetNull)
  location        String // denormalised Area name
  locationDetail  String? // denormalised SubArea name
  description     String // narrative of what happened
  immediateAction String? // what was done at the time
  reportedBy      String // name (or email) of the person the report is attributed to
  reportedById    String? // loose link to User.id (no FK; deleting a user keeps the name)
  witnessCount    Int       @default(0) // denormalised for display
  injuredCount    Int       @default(0) // denormalised for display
  closedAt        DateTime?
  closedBy        String?
  closureNotes    String?

  // ── Phase 1: shared-core report timestamp (set at submit) ──
  reportedAt           DateTime? // when the report was filed; gap = reportedAt - occurredAt

  // ── Phase 1: dual severity — potential axis, set at TRIAGE only ──
  // Nullable (no default): null = "not yet rated", distinct from a genuine 1×1.
  potentialLikelihood  Int? // 1-5
  potentialConsequence Int? // 1-5 (passed as the `severity` arg to the risk engine)

  // ── Phase 1: triage tracking ──
  triagedAt    DateTime?
  triagedBy    String? // loose name, no FK (mirrors closedBy)
  triageStatus String? // Unreviewed | Triaged | ReferredToRA (null => Unreviewed)

  // ── Phase 1: Near-miss / Dangerous-occurrence module ──
  hazardCategory String?  // value from HAZARD_CATEGORIES
  definedDoType  Boolean? // defined Dangerous Occurrence? null = N/A

  // ── Phase 2: per-type modules (all nullable; only the selected type's are set) ──
  // Emergency response (Accident / Aquatic / Medical)
  ambulanceCalled Boolean?
  aedUsed         Boolean?
  cprGiven        Boolean?
  // Accident
  mechanism       String? // how the injury happened
  hsaReportable   Boolean? // advisory HSA-reportable indicator, set at triage
  // Aquatic / water rescue
  aquaticRescueType     String?
  eapLevel              String? // Emergency Action Plan level activated
  lifeguardsOnDuty      Int?
  timeInDifficulty      String? // estimate of time in difficulty / submerged
  spinalManagement      Boolean?
  secondaryDrowningAdvice String? // Given | Refused | NotApplicable
  // Medical
  presentingCondition String?
  conscious           String? // Yes | No | Unknown
  breathing           String? // Yes | No | Unknown
  casualtyHandover    String? // who the casualty was handed over to
  // Facility / environmental / water quality
  afr              Boolean? // accidental faecal / vomit release
  freeChlorine     Float?
  combinedChlorine Float?
  ph               Float?
  correctiveDosing String?
  closureStart     DateTime?
  closureEnd       DateTime?
  samplesSent      Boolean?
  // Security / antisocial
  crimeReference  String?
  gardaiNotified  Boolean?
  ejection        Boolean?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  witnesses          Witness[]
  injuredParties     InjuredParty[]
  followUpActions    FollowUpAction[]
  riskAssessmentLinks IncidentRiskAssessmentLink[]

  @@index([centerId])
  @@index([status])
  @@index([severity])
  @@index([occurredAt])
  @@index([areaId])
  @@index([subAreaId])
  @@index([triageStatus])
  @@index([reportedAt])
}

// Close-out link between an incident and a risk assessment (the 3-outcome flow).
// A first-class join (not a scalar FK) so it survives reopen, distinguishes
// outcome (b) ControlFailureReview from (c) SeededDraft, and can hold > 1 link.
model IncidentRiskAssessmentLink {
  id              String         @id @default(cuid())
  incidentId      String
  incident        Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assessmentId    String
  assessment      RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  linkType        String // ControlFailureReview | SeededDraft
  reviewRequestId String? // soft pointer to the ReviewRequest raised (outcome b); no FK
  note            String?
  createdById     String? // loose link to User.id, no FK
  createdAt       DateTime       @default(now())

  @@unique([incidentId, assessmentId, linkType])
  @@index([incidentId])
  @@index([assessmentId])
}

// A witness to an incident and their statement.
model Witness {
  id             String   @id @default(cuid())
  incidentId     String
  incident       Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  name           String
  roleOrRelation String // "Lifeguard", "Member", "Contractor"…
  contactPhone   String?
  contactEmail   String?
  statement      String
  statementDate  DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([incidentId])
}

// A person injured in an incident.
model InjuredParty {
  id               String    @id @default(cuid())
  incidentId       String
  incident         Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  partyType        String // Staff | Member | Contractor | Visitor | Public
  name             String
  contactPhone     String?
  contactEmail     String?
  address          String?
  dateOfBirth      DateTime?
  gender           String?
  injuryNature     String // "Laceration", "Fracture"…
  bodyPartAffected String // "Left forearm", "Head"…
  treatment        String // None | FirstAidOnly | GpReferral | HospitalAE | HospitalAdmitted
  hospitalName     String?
  gpReferral       Boolean   @default(false)
  lostTime         Boolean   @default(false)
  lostTimeDays     Int?
  additionalNotes  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([incidentId])
}

// A corrective / preventive action raised during an incident investigation.
model FollowUpAction {
  id          String    @id @default(cuid())
  incidentId  String
  incident    Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  description String
  assignedTo  String // free-text name in v1
  dueDate     DateTime
  status      String    @default("Open") // Open | InProgress | Complete | Overdue
  completedAt DateTime?
  completedBy String?
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([incidentId])
  @@index([status])
  @@index([dueDate])
}
