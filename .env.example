# Copy to .env for local development.
#
# Local dev: point these at a local Postgres (`docker compose up -d`) or a Neon "dev" branch.
# Production (Vercel): the Neon integration sets BOTH of these automatically —
#   you normally don't need to add anything by hand.
#
# DATABASE_URL — pooled connection, used by the app at runtime (serverless-safe).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# DATABASE_URL_UNPOOLED — direct (unpooled) connection, used by Prisma for migrations.
# On Neon this is the "unpooled" string. For a local Postgres it can equal DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
